{
  "expo": {
    "name": "MzansiGo",
    "slug": "OfflineEducationApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mzansigo-icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B57C6",
        "foregroundImage": "./assets/mzansigo-icon.png"
      },
      "package": "com.luckyphiri.OfflineEducationApp"
    },
    "web": {
      "favicon": "./assets/mzansigo-icon.png"
    },
    "plugins": [
      "expo-file-system",
      [
        "expo-splash-screen",
        {
          "image": "./assets/mzansigo-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0B57C6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c36faa5e-f89a-43e4-bec8-1ec1c18183e7"
      }
    }
  }
}
